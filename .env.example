DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/brainfriends_dev
DATABASE_SSL=disable
NCP_OBJECT_STORAGE_BUCKET=brainfriends-clinical-media
NCP_OBJECT_STORAGE_ENDPOINT=https://kr.object.ncloudstorage.com
NCP_OBJECT_STORAGE_REGION=kr-standard
NCP_OBJECT_STORAGE_FORCE_PATH_STYLE=true
NCP_ACCESS_KEY=YOUR_NCP_ACCESS_KEY
NCP_SECRET_KEY=YOUR_NCP_SECRET_KEY

# ──────────── 통일 스키마 마이그레이션 기능 플래그 ────────────
# 기본값은 모두 false — 켜지 않는 한 운영 경로는 기존 테이블만 사용한다.
# 자세한 롤백 절차는 docs/decisions/2026-04-21-rollback-playbook.md 참조.
#
# 회원가입/승인 경로에서 신규 users 외 6개 테이블에 이중 쓰기 활성화
USE_NEW_USERS_SCHEMA=false
# 이중 쓰기 실패 시 트랜잭션 자체를 실패시킬지 여부 (초기엔 false, 완전 전환 직전에만 true)
USE_NEW_USERS_SCHEMA_STRICT=false
